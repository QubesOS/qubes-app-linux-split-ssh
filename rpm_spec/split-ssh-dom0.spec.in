Name:		qubes-split-ssh-dom0
Version:	@VERSION@
Release:	1%{dist}
Summary:	Qubes policy for split ssh

Group:		Qubes
Vendor:		Invisible Things Lab
License:	GPL-2.0-or-later
URL:		http://www.qubes-os.org

BuildArch:	noarch

BuildRequires:	make
BuildRequires:	python3-rpm-macros
BuildRequires:	python3-setuptools
BuildRequires:	python3-devel

Requires:	qubes-core-dom0-linux

Source0: qubes-split-ssh-%{version}.tar.gz

%description
Default (deny) qrexec policy for the qubes.SshAgent service used by split ssh.
This package also ships the split-ssh integration tests.

%prep
%setup -q -n qubes-split-ssh-%{version}

%install
rm -rf $RPM_BUILD_ROOT
make install-dom0 DESTDIR=$RPM_BUILD_ROOT
make -C tests install-dom0-py3 DESTDIR=$RPM_BUILD_ROOT

%clean
rm -rf $RPM_BUILD_ROOT

%files
%config(noreplace) %attr(0664,root,qubes) /etc/qubes/policy.d/90-qubes-split-ssh.policy
%dir %{python3_sitelib}/splitssh-*.egg-info
%{python3_sitelib}/splitssh-*.egg-info/*
%{python3_sitelib}/splitssh

%changelog
@CHANGELOG@
